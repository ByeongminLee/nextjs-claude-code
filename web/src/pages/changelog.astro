---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read CHANGELOG.md at build time from the repo root
// process.cwd() is web/ during build, so ../CHANGELOG.md reaches the repo root
const changelogPath = path.resolve(process.cwd(), '../CHANGELOG.md');
let changelogContent = '';
try {
  changelogContent = fs.readFileSync(changelogPath, 'utf-8');
} catch {
  changelogContent = '';
}

interface VersionEntry {
  title: string;
  sections: { heading: string; items: string[] }[];
}

function parseChangelog(content: string): VersionEntry[] {
  const entries: VersionEntry[] = [];
  let current: VersionEntry | null = null;
  let currentSection: { heading: string; items: string[] } | null = null;

  for (const line of content.split('\n')) {
    if (line.startsWith('## [')) {
      if (current) entries.push(current);
      current = { title: line.replace('## ', ''), sections: [] };
      currentSection = null;
    } else if (line.startsWith('### ') && current) {
      currentSection = { heading: line.replace('### ', ''), items: [] };
      current.sections.push(currentSection);
    } else if (line.startsWith('- ') && currentSection) {
      currentSection.items.push(line.replace('- ', ''));
    }
  }
  if (current) entries.push(current);
  return entries;
}

const versions = parseChangelog(changelogContent);
---

<Layout title="Changelog — NCC">
  <Header />
  <main class="max-w-2xl mx-auto px-6 py-16">
    <section class="mb-12">
      <h1 class="font-mono font-bold text-3xl mb-2">Changelog</h1>
      <p class="text-gray-500 leading-relaxed">All notable changes to NCC.</p>
    </section>

    <hr class="border-gray-100 mb-12" />

    {versions.length === 0 && (
      <p class="text-gray-500">No changelog entries found.</p>
    )}

    {versions.map((version, vi) => (
      <>
        {vi === 0 ? (
          /* Latest version — always open */
          <section class="mb-12">
            <h2 class="font-mono font-bold text-xl mb-4">
              {version.title}
              <span class="ml-2 text-xs font-normal text-white bg-gray-900 px-2 py-0.5 rounded-full align-middle">Latest</span>
            </h2>
            {version.sections.map((section) => (
              <div class="mb-6">
                <h3 class="font-mono font-semibold text-base mb-3 text-gray-600">{section.heading}</h3>
                <ul class="space-y-1.5 text-gray-700">
                  {section.items.map((item) => (
                    <li class="flex gap-2">
                      <span class="text-gray-300 select-none">—</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        ) : (
          /* Older versions — accordion */
          <details class="mb-8 group">
            <summary class="font-mono font-bold text-xl cursor-pointer select-none list-none flex items-center gap-2 py-3 hover:text-gray-600 transition-colors">
              <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
              {version.title}
            </summary>
            <div class="pt-2 pb-4">
              {version.sections.map((section) => (
                <div class="mb-6">
                  <h3 class="font-mono font-semibold text-base mb-3 text-gray-600">{section.heading}</h3>
                  <ul class="space-y-1.5 text-gray-700">
                    {section.items.map((item) => (
                      <li class="flex gap-2">
                        <span class="text-gray-300 select-none">—</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </details>
        )}
        {vi < versions.length - 1 && <hr class="border-gray-100 mb-8" />}
      </>
    ))}

    <hr class="border-gray-100 mb-12" />

    <footer class="text-gray-500 text-sm">
      <p>
        <a href="/nextjs-claude-code/" class="underline underline-offset-2 hover:text-gray-900">Back to home</a>
      </p>
    </footer>
  </main>
</Layout>
