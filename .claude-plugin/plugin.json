{
  "name": "nextjs-claude-code",
  "version": "1.0.0",
  "description": "NCC — Spec-Driven AI workflow for Next.js & React. Define features with /spec, implement with /dev, force-complete with /loop.",
  "author": {
    "name": "ByeongminLee"
  },
  "homepage": "https://github.com/ByeongminLee/nextjs-claude-code",
  "repository": "https://github.com/ByeongminLee/nextjs-claude-code",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "nextjs",
    "react",
    "spec-driven",
    "agents",
    "skills",
    "workflow"
  ],
  "agents": "./template/.claude/agents",
  "skills": "./template/.claude/skills",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/template/.claude/scripts/security-guard.sh\"",
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/template/.claude/scripts/validate-post-write.sh\"",
            "statusMessage": "Validating write..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/template/.claude/scripts/advisory-post-write.sh\"",
            "statusMessage": "Running advisory checks..."
          }
        ]
      }
    ]
  }
}
