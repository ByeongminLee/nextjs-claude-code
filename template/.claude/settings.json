{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/security-guard.sh",
            "statusMessage": "Checking command safety..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/validate-post-write.sh",
            "statusMessage": "Validating write..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/advisory-post-write.sh",
            "statusMessage": "Running advisory checks..."
          }
        ]
      }
    ]
  }
}
