{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/validate-spec.sh",
            "statusMessage": "Validating spec format..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/reflect-spec.sh",
            "statusMessage": "Checking spec reflection..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/suggest-skills.sh",
            "statusMessage": "Checking for matching skills..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/security-suggest.sh",
            "statusMessage": "Checking security-sensitive changes..."
          }
        ]
      }
    ]
  }
}
